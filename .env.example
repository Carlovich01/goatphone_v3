# ============ DATABASE (PostgreSQL local + pgvector) ============
# Ajusta usuario/password/puerto segun tu instalacion de PostgreSQL 18
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/goatphone?schema=public"

# ============ AUTH ============
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Admin que se crea con el seed
ADMIN_EMAIL="admin@goatphone.com"
ADMIN_PASSWORD="admin1234"

# ============ GOOGLE GEMINI (AI Studio free tier) ============
GEMINI_API_KEY="tu-api-key-de-google-ai-studio"
GEMINI_MODEL="gemini-flash-lite-latest"
GEMINI_EMBED_MODEL="gemini-embedding-001"
# Limites para cuidar el free tier
AI_MAX_OUTPUT_TOKENS="600"
AI_RAG_TOP_K="6"

# ============ MERCADO PAGO (sandbox Argentina) ============
MP_ACCESS_TOKEN="TEST-xxxxxxxx-tu-access-token-sandbox"
MP_PUBLIC_KEY="TEST-xxxxxxxx-tu-public-key-sandbox"
MP_CURRENCY="ARS"

# ============ URLS ============
API_PORT="3000"
API_URL="http://localhost:3000"
WEB_URL="http://localhost:5173"
# URL publica que Mercado Pago usara para el webhook (usa ngrok en local si querés notificaciones reales)
MP_NOTIFICATION_URL="http://localhost:3000/payments/webhook"
